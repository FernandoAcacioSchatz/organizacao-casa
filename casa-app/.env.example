# ─── Banco de dados MySQL (Aiven — gratuito) ──────────────────────────────────
# Crie seu banco gratuito em: aiven.io (sem cartão de crédito)
# Após criar o serviço MySQL, vá em Overview > Connection information
# e copie os dados abaixo.
#
# ATENÇÃO: a porta do Aiven geralmente é 13306, não 3306!

MYSQL_HOST=seu-servico.aivencloud.com
MYSQL_PORT=13306
MYSQL_USER=avnadmin
MYSQL_PASSWORD=sua_senha_aqui
MYSQL_DATABASE=defaultdb
MYSQL_SSL=true

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=substitua_por_uma_string_longa_e_aleatoria
